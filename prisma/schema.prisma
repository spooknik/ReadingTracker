generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MANGA
  MANHWA
  MANHUA
  LIGHT_NOVEL
  BOOK
}

enum ReadingStatus {
  READING
  COMPLETED
  ON_HOLD
  DROPPED
  PLAN_TO_READ
}

enum RipStatus {
  UNSUPPORTED
  PENDING
  RUNNING
  READY
  FAILED
}

enum RipJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum RipJobKind {
  SYNC
  VERIFY
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")

  createdSeries Series[]     @relation("CreatedBy")
  userSeries    UserSeries[]
  readerProgress ReaderProgress[]

  @@map("users")
}

model Series {
  id            String    @id @default(uuid())
  malId         Int?      @unique @map("mal_id")
  title         String
  imageUrl      String?   @map("image_url")
  synopsis      String?
  mediaType     MediaType @default(MANGA) @map("media_type")
  totalChapters Int?      @map("total_chapters")
  totalVolumes  Int?      @map("total_volumes")
  link          String?
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  createdBy       User             @relation("CreatedBy", fields: [createdById], references: [id])
  userSeries      UserSeries[]
  rip             SeriesRip?
  readerProgress  ReaderProgress[]

  @@map("series")
}

model UserSeries {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  seriesId       String        @map("series_id")
  status         ReadingStatus @default(PLAN_TO_READ)
  currentChapter Int           @default(0) @map("current_chapter")
  rating         Int?
  notes          String?
  updatedAt      DateTime      @updatedAt @map("updated_at")
  joinedAt       DateTime      @default(now()) @map("joined_at")

  user   User   @relation(fields: [userId], references: [id])
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@map("user_series")
}

model SeriesRip {
  id            String    @id @default(uuid())
  seriesId      String    @unique @map("series_id")
  site          String?
  normalizedUrl String?   @map("normalized_url")
  outputDir     String?   @map("output_dir")
  manifestPath  String?   @map("manifest_path")
  status        RipStatus @default(UNSUPPORTED)
  lastError     String?   @map("last_error")
  lastSyncedAt  DateTime? @map("last_synced_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  series Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  jobs   RipJob[]

  @@map("series_rips")
}

model RipJob {
  id          String       @id @default(uuid())
  seriesRipId String       @map("series_rip_id")
  kind        RipJobKind   @default(SYNC)
  status      RipJobStatus @default(QUEUED)
  startedAt   DateTime?    @map("started_at")
  finishedAt  DateTime?    @map("finished_at")
  outputLog   String?      @map("output_log")
  error       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  seriesRip SeriesRip @relation(fields: [seriesRipId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("rip_jobs")
}

model ReaderProgress {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  seriesId    String   @map("series_id")
  chapterSlug String?  @map("chapter_slug")
  pageIndex   Int      @default(0) @map("page_index")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
  @@map("reader_progress")
}
